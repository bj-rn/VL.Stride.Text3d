<Project Sdk="Microsoft.NET.Sdk">

  <!--
    Phase 0 baseline capture tool (historical).
    References the SHIPPED 1.0.2 SharpDX-based build (snapshotted in ./legacy) and dumps
    its vertex output as regression fixtures to ..\baselines. These fixtures proved the
    2.0 Silk.NET port bit-exact. Since 2.1 the committed fixtures are deliberately
    regenerated from the fixed implementation (corrected side-wall normals, see
    tests/VL.Stride.Text3d.Tests/VertexParityTests.cs), so this tool's "verify" mode no
    longer matches them — it is kept as documentation of the original capture process.
  -->

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="SharpDX" Version="4.2.0" />
    <PackageReference Include="SharpDX.Direct2D1" Version="4.2.0" />
    <PackageReference Include="SharpDX.DXGI" Version="4.2.0" />
    <PackageReference Include="SharpDX.Mathematics" Version="4.2.0" />
    <PackageReference Include="Stride.Core.Mathematics" Version="4.1.0.1734" />
    <PackageReference Include="Stride.Graphics" Version="4.1.0.1734" />
    <PackageReference Include="Stride.Rendering" Version="4.1.0.1734" />
  </ItemGroup>

  <ItemGroup>
    <Reference Include="VL.Stride.Text3d">
      <HintPath>legacy\VL.Stride.Text3d.dll</HintPath>
    </Reference>
  </ItemGroup>

</Project>
